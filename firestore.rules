rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidQuizResult() {
      return hasOnlyAllowedFields(['userName', 'subjectId', 'score', 'total', 'createdAt']) &&
             request.resource.data.userName is string &&
             request.resource.data.userName.size() > 0 &&
             request.resource.data.userName.size() < 100 &&
             request.resource.data.subjectId is string &&
             request.resource.data.score is number &&
             request.resource.data.total is number &&
             request.resource.data.createdAt is timestamp;
    }

    match /results/{resultId} {
      // Allow anyone to read results (used by admin dashboard)
      allow read: if true;
      // Allow anyone to submit a quiz result
      allow create: if isValidQuizResult();
      allow update: if false;
      allow delete: if false;
    }
  }
}
